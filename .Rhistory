mod1.1_sinSemestre = lmer(dif_minutos ~ tool*Pregunta + tool + Semestre + (1|id_est),
base1.1, REML = FALSE)
anova(mod1.1, mod1.1_sinPregunta)  # ¿aporta tool:Pregunta?
