#Datos iniciales
z = qnorm(0.975)
p = 0.5        # valor conservador para maximizar la varianza
moe = 0.10     # margen de error del 10%
n_0 = ceiling((z^2 * p * (1 - p)) / moe^2)
cat("Para estimar el porcentaje de pacientes con vacunas pendientes con",
"un 95% de confianza y un margen de error del 10%, se requiere una",
"muestra de", n_0, "expedientes. Se asume población grande",
"(sin corrección por finitud).\n\n")
n = 120
x = 27
phat = x / n
ee = sqrt(phat * (1 - phat) / n)
li = phat - z * ee
ls = phat + z * ee
cat("Con una muestra de", n, "expedientes de los cuales", x,
"tenían al menos una vacuna pendiente, la estimación puntual del",
"porcentaje es", round(phat * 100, 2), "% con un intervalo de",
"confianza al 95% de [", round(li * 100, 2), "% ,",
round(ls * 100, 2), "%].\n\n")
cat("El tamaño de muestra utilizado (n =", n, ") es mayor que el",
"requerido en el punto 1 (n =", n_0, "), por lo que el estudio",
"cumple con los objetivos de precisión establecidos.\n\n")
#Datos iniciales
N = 500            # hogares en el vecindario
media_prev = 235000  # deuda promedio en estudio anterior (colones)
s = 200000         # desviación estándar en estudio anterior (colones)
CV_objetivo = 0.1  # coeficiente de variación máximo deseado
# Tamaño de muestra (MIA)
ee_objetivo = CV_objetivo * media_prev   # error estándar máximo tolerable
V2 = ee_objetivo^2
n_0 = s^2 / V2
n_mia = ceiling(n_0 / (1 + n_0/N))
cat("Para obtener un coeficiente de variación de la media no mayor a 0.1,",
"bajo un diseño MIA se requiere una muestra de", n_mia, "hogares",
"(de los", N, "en el vecindario).\n\n")
# Con estratificación (reducción del 6% en la varianza)
deff = 1 - 0.06    # deff = 0.94
n_est = ceiling(n_mia * deff)
cat("Considerando que la estratificación reduce la variancia en un 6%",
"(deff = 0.94), el tamaño de muestra necesario se reduce a",
n_est, "hogares.\n\n")
#Datos iniciales
replica     = 1:10
fumadores   = c(16, 20, 18, 17, 14, 15, 19, 13, 19, 17)
tam_replica = c(94, 85, 85, 80, 82, 79, 86, 82, 93, 88)
c_replicas = length(replica)
# Proporción por réplica
p_gamma = fumadores / tam_replica
# Estimador replicado: media de las proporciones por réplica
p_bar = mean(p_gamma)
# Varianza del muestreo replicado (sin corrección por finitud)
var_p = (1 / (c_replicas * (c_replicas - 1))) * sum((p_gamma - p_bar)^2)
ee_p = sqrt(var_p)
t_val = qt(0.975, df = c_replicas - 1)
li = p_bar - t_val * ee_p
ls = p_bar + t_val * ee_p
cat("El porcentaje estimado de fumadores en el centro penitenciario es de",
round(p_bar * 100, 2), "% con un intervalo de confianza al 95% de [",
round(li * 100, 2), "% ,", round(ls * 100, 2), "%].\n\n")
