#Datos iniciales
N = 1836291
y_barra = 25000
ee = 833.16
n = 500
z = qnorm(0.975)
s = ee/sqrt((1/n)*(1-n/N))
moe = 0.10 * y_barra
n_0 = (z*s/moe)^2
n = ceiling(n_0/(1+n_0/N))
cat("Para obtener un margen de error no mayor al 10% de la media con un",
"95% de confianza, se requiere entrevistar un mínimo de", n,
"viviendas.\n\n")
n_a = ceiling(n/0.5)
cat("(2) Dado que solo el 50% de las viviendas tienen mascota, el tamaño de",
"muestra a seleccionar del marco debe ajustarse a", n_a,
"viviendas para garantizar las", n, "entrevistas válidas requeridas.\n\n")
# (3)
n_800 = 800
ee_800 = sqrt((s^2/n_800)*(1-n_800/N))
ancho = 2*z*ee_800
cat("(3) Con recursos para entrevistar 800 viviendas, el ancho esperado del",
"intervalo de confianza al 95% para el gasto mensual sería de",
round(ancho, 2), "colones.\n\n")
# (4)
prob = n_a/N
factor_expansion = 1/prob
cat("(4) Bajo el diseño del punto 2, la probabilidad de selección de cada",
"vivienda es de", round(prob, 6), "y el factor de expansión es de",
round(factor_expansion, 2), "es decir, cada vivienda seleccionada",
"representa aproximadamente", round(factor_expansion, 0),
"viviendas en la población.\n\n")
